# Nostr Relays for NWC
NEXT_PUBLIC_NWC_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
# Your Citadel Academy Nostr pubkey (optional)
NEXT_PUBLIC_CITADEL_PUBKEY=your_academy_pubkey_here

# LNBits Configuration
LNBITS_URL=https://legend.lnbits.com
LNBITS_ADMIN_KEY=your_lnbits_admin_key
LNBITS_INVOICE_READ_KEY=your_lnbits_invoice_read_key

# Nostr Keys for Zap Receipts and NIP-72 Communities
ACADEMY_PRIVATE_KEY=your_academy_private_key_here

# NIP-72 Community Configuration
NEXT_PUBLIC_COMMUNITY_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
NEXT_PUBLIC_COMMUNITY_MODERATORS=pubkey1,pubkey2

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000